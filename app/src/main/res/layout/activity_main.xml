<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07070d">

    <!-- WebView (full screen) -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#07070d" />

    <!-- Splash Screen overlay -->
    <LinearLayout
        android:id="@+id/splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#07070d"
        android:paddingBottom="60dp">

        <!-- Glow background circle -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <!-- Outer glow -->
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/logo_glow"
                android:layout_gravity="center"
                android:alpha="0.3" />

            <!-- Inner circle -->
            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/logo_bg"
                android:layout_gravity="center" />

            <!-- Logo emoji -->
            <TextView
                android:id="@+id/logo_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️"
                android:textSize="52sp"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- App title -->
        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GoLike Bot"
            android:textColor="#ee4d2d"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v8 · Gemini AI · Auto Captcha"
            android:textColor="#3a3a5c"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="48dp" />

        <!-- Feature badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️ Shopee"
                android:textColor="#ee4d2d"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="@drawable/badge_red"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟠 Lazada"
                android:textColor="#ff8c00"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="@drawable/badge_orange"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Gemini"
                android:textColor="#b39ddb"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="@drawable/badge_purple"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminate="true"
            android:indeterminateTint="#ee4d2d"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang khởi động..."
            android:textColor="#ffb300"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</FrameLayout>

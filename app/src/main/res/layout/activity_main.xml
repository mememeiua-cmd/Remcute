<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:padding="16dp"
      android:background="#0d1117">

      <TextView
          android:id="@+id/tvStatus"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Dang dung"
          android:textColor="#f85149"
          android:textSize="18sp"
          android:textStyle="bold"
          android:paddingBottom="8dp"/>

      <TextView
          android:id="@+id/tvAccessStatus"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Accessibility: Chua kich hoat"
          android:textColor="#f85149"
          android:textSize="14sp"
          android:paddingBottom="4dp"/>

      <TextView
          android:id="@+id/tvOverlayStatus"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Overlay: Chua cap quyen"
          android:textColor="#f85149"
          android:textSize="14sp"
          android:paddingBottom="12dp"/>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:paddingBottom="8dp">

          <Button
              android:id="@+id/btnStart"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Bat dau"
              android:layout_marginEnd="4dp"/>

          <Button
              android:id="@+id/btnStop"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Dung lai"
              android:layout_marginStart="4dp"/>
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:paddingBottom="8dp">

          <Button
              android:id="@+id/btnAccessibility"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Accessibility"
              android:textSize="12sp"
              android:layout_marginEnd="4dp"/>

          <Button
              android:id="@+id/btnOverlay"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Overlay"
              android:textSize="12sp"
              android:layout_marginStart="4dp"/>
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:paddingBottom="12dp">

          <Button
              android:id="@+id/btnAppInfo"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="App Info"
              android:textSize="12sp"
              android:layout_marginEnd="4dp"/>

          <Button
              android:id="@+id/btnClearLog"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Xoa Log"
              android:textSize="12sp"
              android:layout_marginStart="4dp"/>
      </LinearLayout>

      <TextView
          android:id="@+id/tvLog"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:text="Log...
"
          android:textColor="#8b949e"
          android:textSize="12sp"
          android:fontFamily="monospace"
          android:background="#161b22"
          android:padding="8dp"
          android:scrollbars="vertical"/>

  </LinearLayout>
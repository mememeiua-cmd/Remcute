<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07070D"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="40dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="GoLike Helper"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GoLike Helper"
                    android:textSize="22sp"
                    android:textColor="#EE4D2D"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto Captcha Solver v2.0"
                    android:textSize="12sp"
                    android:textColor="#4A4A6A"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvRunBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● STOP"
                android:textSize="11sp"
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:background="@drawable/badge_stop"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- ── DIVIDER ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#12122A"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- ── STATUS CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRẠNG THÁI"
                android:textSize="10sp"
                android:textColor="#4A4A6A"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang dừng"
                android:textSize="18sp"
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvPort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP: localhost:7788"
                android:textSize="12sp"
                android:textColor="#4A4A6A"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── SECTION LABEL ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QUYỀN HẠN"
            android:textSize="10sp"
            android:textColor="#4A4A6A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- Accessibility Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility"
                    android:textSize="13sp"
                    android:textColor="#D0D8E8"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvAccessStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa kích hoạt ✗"
                    android:textSize="11sp"
                    android:textColor="#FF5252"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Bật"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1F3A8F"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"/>

        </LinearLayout>

        <!-- Overlay Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overlay (Hiển thị trên app)"
                    android:textSize="13sp"
                    android:textColor="#D0D8E8"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvOverlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa cấp quyền ✗"
                    android:textSize="11sp"
                    android:textColor="#FF5252"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnOverlay"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cấp"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1F3A8F"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"/>

        </LinearLayout>

        <!-- Screen Capture Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chụp màn hình"
                    android:textSize="13sp"
                    android:textColor="#D0D8E8"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvScreenStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tự cấp khi nhấn Start ✗"
                    android:textSize="11sp"
                    android:textColor="#4A4A6A"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textSize="10sp"
                android:textColor="#4A4A6A"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- ── ANDROID 13/14 FIX ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_warn"
            android:padding="14dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠  Android 13/14: 'Chế độ cài đặt bị hạn chế'"
                android:textSize="12sp"
                android:textColor="#FFB300"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cách 1 (tay):\n① Nhấn 'Mở App Info' bên dưới\n② Nhấn ⋮ (3 chấm) góc trên phải\n③ Chọn 'Cho phép cài đặt bị hạn chế'\n④ Quay lại → Nhấn 'Bật Accessibility'"
                android:textSize="11sp"
                android:textColor="#C0C0D0"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"/>

            <Button
                android:id="@+id/btnAppInfo"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="① Mở App Info"
                android:textSize="12sp"
                android:textColor="#FFB300"
                android:backgroundTint="#1A1200"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- ── ADB BYPASS BOX ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_adb"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💻  Cách 2 — ADB (nhanh hơn, 1 lần duy nhất):"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kết nối điện thoại vào PC, bật USB Debug, chạy:"
                android:textSize="10sp"
                android:textColor="#6090B0"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvAdbCmd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="adb shell cmd appops set com.golikehelper REQUEST_INSTALL_PACKAGES allow"
                android:textSize="10sp"
                android:textColor="#00E5A0"
                android:fontFamily="monospace"
                android:background="#030308"
                android:padding="8dp"
                android:layout_marginTop="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnCopyAdb"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="📋 Copy lệnh"
                    android:textSize="11sp"
                    android:textColor="#00E5A0"
                    android:backgroundTint="#0A1A0A"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnAdbStep2"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="② Bật Accessibility"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1F3A8F"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── ACTION BUTTONS ── -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  KHỞI ĐỘNG SERVER"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#238636"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="■  DỪNG SERVER"
            android:textSize="13sp"
            android:textColor="#D0D8E8"
            android:backgroundTint="#161B22"
            android:layout_marginBottom="16dp"/>

        <!-- ── STATS GRID ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THỐNG KÊ PHIÊN"
            android:textSize="10sp"
            android:textColor="#4A4A6A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvRequestCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#58A6FF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requests"
                    android:textSize="9sp"
                    android:textColor="#4A4A6A"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp">

                <TextView
                    android:id="@+id/tvScreenshotCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#00E5A0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ảnh chụp"
                    android:textSize="9sp"
                    android:textColor="#4A4A6A"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvClickCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#EE4D2D"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clicks"
                    android:textSize="9sp"
                    android:textColor="#4A4A6A"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── API ENDPOINTS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API ENDPOINTS"
                android:textSize="10sp"
                android:textColor="#4A4A6A"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GET  /ping          → trạng thái"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GET  /status        → thông tin đầy đủ"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /screenshot    → base64 JPEG"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /tap  {x,y}    → click 1 điểm"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /click  [{x,y,delay},...] → multi"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /swipe {x1,y1,x2,y2,dur}"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /longpress {x,y,duration}"
                android:textSize="11sp"
                android:textColor="#58A6FF"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POST /solve_captcha → AI tự giải"
                android:textSize="11sp"
                android:textColor="#B39DDB"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- ── LOG SECTION ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LOG HOẠT ĐỘNG"
                android:textSize="10sp"
                android:textColor="#4A4A6A"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Xóa"
                android:textSize="11sp"
                android:textColor="#9090B0"
                android:backgroundTint="#12122A"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:text="Chờ lệnh...\n"
            android:textColor="#3FB950"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="@drawable/log_bg"
            android:scrollbars="vertical"
            android:gravity="top"/>

    </LinearLayout>

</ScrollView>

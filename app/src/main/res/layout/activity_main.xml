<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GoLike Helper"
            android:textSize="30sp"
            android:textColor="#58a6ff"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Captcha Solver v1.0"
            android:textSize="13sp"
            android:textColor="#8b949e"
            android:layout_marginTop="4dp"/>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161b22"
            android:padding="16dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRANG THAI HE THONG"
                android:textSize="11sp"
                android:textColor="#8b949e"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dang dung"
                android:textSize="20sp"
                android:textColor="#f85149"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvPort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP: localhost:7788"
                android:textSize="13sp"
                android:textColor="#8b949e"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvAccessStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accessibility: Chua kich hoat"
                android:textSize="13sp"
                android:textColor="#f85149"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="KHOI DONG SERVER"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:backgroundTint="#238636"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="DUNG SERVER"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#21262d"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAP QUYEN (bat buoc)"
            android:textSize="11sp"
            android:textColor="#8b949e"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cap quyen Accessibility Service"
            android:textSize="13sp"
            android:backgroundTint="#1f6feb"/>

        <Button
            android:id="@+id/btnOverlay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cap quyen Hien thi tren ung dung khac"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#388bfd"/>

        <!-- Log -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOG HOAT DONG"
            android:textSize="11sp"
            android:textColor="#8b949e"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:text="Chua co log...\n"
            android:textColor="#3fb950"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#010409"
            android:scrollbars="vertical"
            android:gravity="top"/>

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Xoa log"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#21262d"/>

        <!-- API Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161b22"
            android:padding="14dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API ENDPOINTS (Python bot goi)"
                android:textSize="11sp"
                android:textColor="#8b949e"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GET  /ping\nPOST /screenshot  -> base64 jpg\nPOST /tap   {x:100, y:200}\nPOST /click [{x,y},{x,y},...]"
                android:textSize="12sp"
                android:textColor="#58a6ff"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
